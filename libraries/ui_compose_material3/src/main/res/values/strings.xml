<resources>
  <!-- Accessibility description for a media control button that causes playback to be started. [CHAR LIMIT=NONE] -->
  <string name="playpause_button_play">Play</string>
  <!-- Accessibility description for a media control button that causes playback to be paused. [CHAR LIMIT=NONE] -->
  <string name="playpause_button_pause">Pause</string>
  <!-- Accessibility description for a media control button that causes the next track to be played. [CHAR LIMIT=NONE] -->
  <string name="next_button">Next</string>
  <!-- Accessibility description for a media control button that causes the previous track to be played. [CHAR LIMIT=NONE] -->
  <string name="previous_button">Previous</string>
  <!-- Accessibility description for a media control button that causes playback to go back. [CHAR LIMIT=NONE] -->
  <string name="seek_back_button">Rewind</string>
  <!-- Accessibility description for a media control button that causes playback to go back by a specified number of seconds. [CHAR LIMIT=NONE] -->
  <plurals name="seek_back_by_amount_button">
    <item quantity="one">Skip back %d second</item>
    <item quantity="other">Skip back %d seconds</item>
  </plurals>
  <!-- Accessibility description for a media control button that causes playback to go forward. [CHAR LIMIT=NONE] -->
  <string name="seek_forward_button">Skip forward</string>
  <!-- Accessibility description for a media control button that causes playback to go forward by a specified number of seconds. [CHAR_LIMIT=NONE] -->
  <plurals name="seek_forward_by_amount_button">
    <item quantity="one">Skip forward %d second</item>
    <item quantity="other">Skip forward %d seconds</item>
  </plurals>
  <!-- Accessibility description for a button that controls the repeat mode of a media playback. In this mode media is not repeated. If the user clicks the button, the repeat mode changes to the next available mode. [CHAR LIMIT=NONE] -->
  <string name="repeat_button_repeat_off">Current mode: Repeat none. Toggle repeat mode.</string>
  <!-- Accessibility description for a button that controls the repeat mode of a media playback. In this mode the current piece of media is repeated. If the user clicks the button, the repeat mode changes to the next available mode. [CHAR LIMIT=NONE] -->
  <string name="repeat_button_repeat_one">Current mode: Repeat one. Toggle repeat mode.</string>
  <!-- Accessibility description for a button that controls the repeat mode of a media playback. In this mode the entire playlist is repeated. If the user clicks the button, the repeat mode changes to the next available mode. [CHAR LIMIT=NONE] -->
  <string name="repeat_button_repeat_all">Current mode: Repeat all. Toggle repeat mode.</string>
  <!-- Accessibility description for a button that controls the shuffle mode of media playback. In this mode shuffle is on. If the user clicks the button, shuffle mode will be turned off. [CHAR LIMIT=NONE] -->
  <string name="shuffle_button_shuffle_on">Shuffle mode enabled.</string>
  <!-- Accessibility description for a button that controls the shuffle mode of media playback. In this mode shuffle is off. If the user clicks the button, shuffle mode will be turned on. [CHAR LIMIT=NONE] -->
  <string name="shuffle_button_shuffle_off">Shuffle mode disabled.</string>
  <!-- Accessibility description for a mute button in the unmuted state. If a user clicks it, the player's volume will be changed to zero. [CHAR_LIMIT=NONE] -->
  <string name="mute_button_shown_unmuted">Mute</string>
  <!-- Accessibility description for a mute button in the muted state. If a user clicks it, the player's volume will be changed to whatever it was previously before muting. [CHAR_LIMIT=NONE] -->
  <string name="mute_button_shown_muted">Unmute</string>
  <!-- Accessibility description for a button that increases the playback speed. [CHAR_LIMIT=NONE] -->
  <string name="playback_speed_increase">Increase speed by %.2f</string>
  <!-- Accessibility description for a button that decreases the playback speed. [CHAR_LIMIT=NONE] -->
  <string name="playback_speed_decrease">Decrease speed by %.2f</string>
  <string name="playback_speed_format" translatable="false">%.2fx</string>
